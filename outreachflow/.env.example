# ─────────────────────────────────────────────────────────────
# OutreachFlow Environment Variables Template
# Copy this file to .env and fill in your actual API keys.
# ─────────────────────────────────────────────────────────────

# Required API Keys
OCEAN_API_KEY=your_ocean_io_api_key_here
PROSPEO_API_KEY=your_prospeo_api_key_here
BREVO_API_KEY=your_brevo_api_key_here

# Optional Sender Details (Defaults are loaded in config.py if omitted)
BREVO_SENDER_EMAIL=sreenath@outreachflow.me
BREVO_SENDER_NAME=Sreenath

# Optional Configuration Limits
MAX_COMPANIES=5
MAX_CONTACTS_PER_COMPANY=2
MAX_EMAILS_TO_SEND=10
